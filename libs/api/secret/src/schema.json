{
  "$id": "http://spica.internal/secret",
  "type": "object",
  "required": ["key", "value"],
  "properties": {
    "_id": {
      "type": "string",
      "format": "objectid",
      "description": "Unique objectid id of schema."
    },
    "key": {
      "title": "Key",
      "description": "Secret key name",
      "type": "string",
      "examples": ["DB_PASSWORD", "API_TOKEN"]
    },
    "value": {
      "title": "Value",
      "description": "Secret value (will be encrypted at rest)",
      "type": "string",
      "examples": ["my-secret-value"]
    }
  },
  "additionalProperties": false
}
