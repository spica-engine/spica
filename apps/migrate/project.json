{
  "name": "migrate",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/migrate/src",
  "projectType": "application",
  "targets": {
    "compile": {
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["build"],
      "options": {
        "runInBand": true
      }
    },
    "test-image": {
      "command": "docker build --target test --platform=linux/amd64 . -f ./apps/migrate/Dockerfile",
      "cache": true
    },
    "build-image": {
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/project.json",
        "{projectRoot}/Dockerfile"
      ],
      "command": "docker buildx build --platform=linux/amd64 --load --target runner --cache-from type=gha,scope=migrate --cache-to type=gha,scope=migrate,mode=max -f ./apps/migrate/Dockerfile -t spicaengine/migrate:$VERSION .",
      "cache": true
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-image"],
      "options": {
        "command": "docker push spicaengine/migrate:$VERSION"
      }
    }
  }
}
