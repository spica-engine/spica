{
  "name": "migrate",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/migrate/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build",
        "buildTargetOptions": {
          "outputPath": "apps/migrate/dist",
          "outputFileName": "src/main.js"
        }
      }
    },
    "build-test": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/migrate",
        "command": "tsc -p tsconfig.test.json"
      },
      "inputs": [
        "{projectRoot}/test/**/*.ts",
        "{projectRoot}/tsconfig.test.json",
        "{projectRoot}/tsconfig.json"
      ],
      "outputs": ["{projectRoot}/dist/test"]
    },
    "test": {
      "dependsOn": ["build-test"],
      "options": {
        "runInBand": true
      }
    },
    "prune": {
      "dependsOn": ["build"],
      "command": "yarn prune:migrate"
    },
    "docker:build": {
      "dependsOn": ["prune"],
      "command": "docker build .",
      "options": {
        "cwd": "apps/migrate",
        "args": [
          "--tag spicaengine/migrate:${VERSION-'latest'}",
          "--platform ${PLATFORM-'linux/arm64'}"
        ]
      }
    }
  }
}
