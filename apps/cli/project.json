{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cli",
  "projectType": "application",
  "tags": [],
  "targets": {
    "compile": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{workspaceRoot}/dist/apps/cli"],
      "options": {
        "main": "apps/cli/index.ts",
        "tsConfig": "apps/cli/tsconfig.json",
        "outputPath": "dist/apps/cli",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "thirdParty": false,
        "generatePackageJson": true,
        "skipTypeCheck": true,
        "declaration": false,
        "assets": [
          {
            "glob": "spica",
            "input": "apps/cli/bin",
            "output": "bin"
          }
        ]
      }
    },
    "set-version": {
      "dependsOn": ["compile"]
    }
  }
}
