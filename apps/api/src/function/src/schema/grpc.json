{
  "$id": "http://spica.internal/function/enqueuer/grpc",
  "title": "gRPC",
  "description": "gRPC enqueuer for functions",
  "type": "object",
  "required": ["requestParams", "responseParams"],
  "properties": {
    "requestParams": {
      "title": "Request Parameters",
      "description": "Parameters for the gRPC request message",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "title": "Name",
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "type": {
            "title": "Type",
            "type": "string",
            "enum": ["string", "int32", "int64", "float", "double", "bool", "bytes"]
          }
        },
        "additionalProperties": false
      }
    },
    "responseParams": {
      "title": "Response Parameters",
      "description": "Parameters for the gRPC response message",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "title": "Name",
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "type": {
            "title": "Type",
            "type": "string",
            "enum": ["string", "int32", "int64", "float", "double", "bool", "bytes"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
