{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build",
        "buildTargetOptions": {
          "outputPath": "apps/api/dist",
          "outputFileName": "src/main.js"
        }
      }
    },
    "prune": {
      "dependsOn": ["build"],
      "command": "yarn prune:api"
    },
    "docker:build": {
      "dependsOn": ["prune"],
      "command": "docker build .",
      "options": {
        "cwd": "apps/api",
        "args": [
          "--tag spicaengine/api:${VERSION-'latest'}",
          "--platform ${PLATFORM-'linux/arm64'}"
        ]
      }
    }
  }
}
