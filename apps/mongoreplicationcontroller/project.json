{
  "name": "mongoreplicationcontroller",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mongoreplicationcontroller/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "mongoreplicationcontroller:build"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "inputs": [
        "{workspaceRoot}/tsconfig.json",
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/project.json"
      ],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/mongoreplicationcontroller",
        "main": "apps/mongoreplicationcontroller/src/main.ts",
        "tsConfig": "apps/mongoreplicationcontroller/tsconfig.json"
      },
      "cache": true
    },
    "build-image": {
      "inputs": [
        "{workspaceRoot}/tsconfig.json",
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/project.json",
        "{projectRoot}/Dockerfile"
      ],
      "command": "docker buildx build --platform=linux/amd64 --load --target runner --cache-from type=gha,scope=mongoreplicationcontroller --cache-to type=gha,scope=mongoreplicationcontroller,mode=max -f ./apps/mongoreplicationcontroller/Dockerfile -t spicaengine/mongoreplicationcontroller:$VERSION .",
      "cache": true
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-image"],
      "options": {
        "command": "docker push spicaengine/mongoreplicationcontroller:$VERSION"
      }
    }
  }
}
