{
  "name": "mongoreplicationcontroller",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mongoreplicationcontroller/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "mongoreplicationcontroller:build",
        "buildTargetOptions": {
          "outputPath": "apps/mongoreplicationcontroller/dist",
          "outputFileName": "src/main.js"
        }
      }
    },
    "prune": {
      "dependsOn": ["build"],
      "command": "yarn prune:mongoreplicationcontroller"
    },
    "docker:build": {
      "dependsOn": ["prune"],
      "command": "docker build .",
      "options": {
        "cwd": "apps/mongoreplicationcontroller",
        "args": [
          "--tag spicaengine/mongoreplicationcontroller:${VERSION-'latest'}",
          "--platform ${PLATFORM-'linux/arm64'}"
        ]
      }
    }
  }
}
