{
  "name": "api/bucket/expression",
  "sourceRoot": "packages/api/bucket/expression/src",
  "projectType": "library",
  "targets": {
    "build": {
      "dependsOn": ["build-assets"]
    },
    "build-assets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p {projectRoot}/dist/src && cp {projectRoot}/src/grammar.pegjs {projectRoot}/dist/src/grammar.pegjs"
      }
    }
  }
}
