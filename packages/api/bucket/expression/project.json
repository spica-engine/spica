{
  "name": "api/bucket/expression",
  "sourceRoot": "packages/api/bucket/expression/src",
  "projectType": "library",
  "targets": {
    "build": {
      "dependsOn": ["build-assets"]
    },
    "build-assets": {
      "executor": "nx:run-commands",
      "options": {
       "command": "shx mkdir -p packages/api/bucket/expression/dist/src && shx cp packages/api/bucket/expression/src/grammar.pegjs packages/api/bucket/expression/dist/src/grammar.pegjs"
      }
    }
  }
}
