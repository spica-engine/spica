{
  "name": "api/function/runtime/node/bootstrap",
  "sourceRoot": "packages/api/function/runtime/node/bootstrap",
  "projectType": "library",
  "implicitDependencies": [
    "api/bucket/hooks/proto",
    "api/bucket/hooks/proto/node",
    "api/function/queue/node",
    "api/function/queue/proto",
    "api/function/runtime/logger",
    "devkit/database"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/tsconfig.json",
        "{workspaceRoot}/tsconfig.base.json",
        {
          "externalDependencies": [
            "rollup",
            "typescript",
            "@rollup/plugin-commonjs",
            "@rollup/plugin-json",
            "@rollup/plugin-node-resolve",
            "@rollup/plugin-terser",
            "@rollup/plugin-typescript",
            "rollup-plugin-copy"
          ]
        }
      ],
      "outputs": ["{workspaceRoot}/packages/api/function/runtime/node/dist/bootstrap"],
      "options": {
        "command": "yarn rollup -c './packages/api/function/runtime/node/bootstrap/rollup.config.js' --bundleConfigAsCjs"
      },
      "cache": true
    }
  }
}
