{
  "name": "api/function/runtime/node/bootstrap",
  "sourceRoot": "packages/api/function/runtime/node/bootstrap",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/tsconfig.json",
        "{workspaceRoot}/tsconfig.base.json"
      ],
      "outputs": ["{workspaceRoot}/packages/api/function/runtime/node/dist/bootstrap"],
      "options": {
        "command": "yarn rollup -c './packages/api/function/runtime/node/bootstrap/rollup.config.js' --bundleConfigAsCjs"
      },
      "cache": true
    }
  }
}
