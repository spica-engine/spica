{
  "name": "@spica-server/core-schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./formats": {
      "types": "./formats.ts",
      "default": "./dist/formats.js"
    },
    "./defaults": {
