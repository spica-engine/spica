      "default": "./dist/src/validator.js"
    }
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^11.1.27",
    "@spica-server/core-encryption": "workspace:*",
    "@spica-server/interface-config": "workspace:*",
    "@spica-server/interface-core": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "got": "^14.4.9",
    "mongodb": "^6.12.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15"
  }
