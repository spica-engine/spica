{
  "name": "@spica-server/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./testing/index.ts",
      "default": "./testing/dist/index.js"
    },
    "./realtime": {
      "types": "./realtime/index.ts",
      "default": "./realtime/dist/index.js"
    },
    "./realtime/src/database.service": {
      "types": "./realtime/src/database.service.ts",
      "default": "./realtime/dist/src/database.service.js"
    },
    "./realtime/src/levenshtein": {
      "types": "./realtime/src/levenshtein.ts",
      "default": "./realtime/dist/src/levenshtein.js"
    },
    "./pipeline": {
      "types": "./pipeline/index.ts",
      "default": "./pipeline/dist/index.js"
    }
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@spica-server/filter": "workspace:*",
    "@spica-server/interface": "workspace:*",
    "lodash": "^4.17.21",
    "mingo": "^6.5.1",
    "mongodb": "^6.12.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/lodash": "^4.17.14",
    "mongodb-memory-server": "^10.1.3",
    "testcontainers": "^10.0.0"
  }
}
