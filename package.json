  "scripts": {
    "format:check": "yarn nx format:check",
    "format": "yarn nx format:write",
    "build:*": "yarn nx run-many -t build",
    "build:api": "yarn nx build api",
    "prune:api": "node scripts/prune.mjs api",
    "prune:migrate": "node scripts/prune.mjs migrate",
    "prune:mongoreplicationcontroller": "node scripts/prune.mjs mongoreplicationcontroller",
    "prune:devkit:auth": "node scripts/prune.mjs devkit/auth",
    "build:panel": "yarn nx build panel",
    "serve:api": "yarn nx serve api",
    "serve:panel": "yarn nx serve panel",
    "serve:watch:api": "yarn nx serve:watch api",
    "build:cli": "yarn nx build cli",
    "build:migrate": "yarn nx compile migrate",
    "build:mongoreplicationcontroller": "yarn nx build mongoreplicationcontroller",
    "build:devkit:bucket": "yarn nx build devkit/bucket",
    "build:devkit:database": "yarn nx build devkit/database",
    "build:devkit:identity": "yarn nx build devkit/identity",
    "build:devkit:storage": "yarn nx build devkit/storage",
    "build:devkit:testing": "yarn nx build devkit/testing",
    "build:devkit:*": "yarn nx run-many -t build --projects=devkit/**",
    "build-image:*": "yarn nx run-many -t build-image",
    "build-image:panel": "yarn nx build-image panel",
    "build-image:api": "yarn nx build-image api",
    "build-image:migrate": "yarn nx build-image migrate",
    "build-image:mongoreplicationcontroller": "yarn nx build-image mongoreplicationcontroller",
    "test:*": "yarn nx run-many -t test",
    "test:local:*": "yarn nx run-many -t test -c local",
    "test:api": "yarn nx run-many -t test --projects=api/** --projects=filter --projects=cli --projects=core --projects=core/** --projects=database/** --exclude=devkit/**",
    "test:cli": "yarn nx test cli",
    "test:migrate": "yarn nx test migrate",
    "test:devkit:bucket": "yarn nx test devkit/bucket",
    "test:devkit:database": "yarn nx test devkit/database",
    "test:devkit:identity": "yarn nx test devkit/identity",
    "test:devkit:storage": "yarn nx test devkit/storage",
    "test:devkit:testing": "yarn nx test devkit/testing",
    "test:devkit:*": "yarn nx run-many -t test --projects=devkit/**",
    "test-image:*": "yarn nx run-many -t test-image",
    "test-image:api": "yarn nx test-image api",
    "test-image:core": "yarn nx test-image api --build-arg PROJECTS=core/**",
    "test-image:database": "yarn nx test-image api --build-arg PROJECTS=database/**",
    "test-image:filter": "yarn nx test-image api --build-arg PROJECTS=filter/**",
    "test-image:migrate": "yarn nx test-image migrate",
    "publish:devkit:bucket": "yarn nx nx-release-publish devkit/bucket",
    "publish:devkit:database": "yarn nx nx-release-publish devkit/database",
    "publish:devkit:identity": "yarn nx nx-release-publish devkit/identity",
    "publish:devkit:storage": "yarn nx nx-release-publish devkit/storage",
    "publish:devkit:testing": "yarn nx nx-release-publish devkit/testing",
    "publish:devkit:auth": "yarn nx nx-release-publish devkit/auth",
    "publish:cli": "yarn nx nx-release-publish cli",
